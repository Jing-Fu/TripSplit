# ===========================
# Database (Supabase Postgres)
# ===========================
# Supabase Pooler URL (Transaction mode) - 給 app runtime 使用
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Direct URL - 給 prisma migrate 使用
DATABASE_DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ===========================
# Session
# ===========================
# 用於簽名 session cookie 的隨機字串（至少 32 字元）
SESSION_SECRET="your-random-session-secret-at-least-32-chars"

# ===========================
# LINE Messaging API (Webhook + Push)
# ===========================
# LINE Developers Console > Messaging API Channel > Basic settings
LINE_CHANNEL_ID="your-messaging-channel-id"
LINE_CHANNEL_SECRET="your-messaging-channel-secret"
LINE_CHANNEL_ACCESS_TOKEN="your-channel-access-token"

# ===========================
# LIFF (LINE Front-end Framework)
# ===========================
# LINE Developers Console > LIFF > LIFF ID
LIFF_ID="your-liff-id"
# 用於 server-side 驗證 LIFF ID Token 的 audience（= LIFF Channel ID）
LIFF_CHANNEL_ID="your-liff-channel-id"
# 前端使用（NEXT_PUBLIC_ 前綴）
NEXT_PUBLIC_LIFF_ID="your-liff-id"

# ===========================
# LINE Login (Web OAuth fallback，非 LIFF 環境使用)
# ===========================
LINE_LOGIN_CHANNEL_ID="your-line-login-channel-id"
LINE_LOGIN_CHANNEL_SECRET="your-line-login-channel-secret"
# 必須在 LINE Login Channel 的 Callback URL 中設定
LINE_LOGIN_REDIRECT_URI="https://your-app.vercel.app/api/auth/line/oauth/callback"

# ===========================
# Cloudflare R2 (Object Storage)
# ===========================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="tripsplit-prod"
# R2 自訂域名或 r2.dev 公開 URL（用於 signed URL 的 base）
R2_PUBLIC_BASE_URL="https://your-bucket.your-account.r2.cloudflarestorage.com"

# ===========================
# App
# ===========================
# 外部可訪問的 base URL（用於 webhook 設定、OAuth callback 等）
APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ===========================
# Vercel Cron
# ===========================
# 用於保護 Cron endpoint 的隨機字串
CRON_SECRET="your-random-cron-secret"

# ===========================
# Notion Export (Optional)
# ===========================
# 若要啟用 Notion 匯出功能，填入以下兩個值
NOTION_TOKEN=""
NOTION_PARENT_PAGE_ID=""
