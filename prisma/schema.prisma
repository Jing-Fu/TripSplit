generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trip {
  id          String   @id @default(cuid())
  name        String
  description String?
  destination String?
  startDate   DateTime
  endDate     DateTime?
  currency    String   @default("TWD")
  inviteCode  String   @unique
  coverEmoji  String   @default("✈️")
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User?               @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  Member[]
  expenses Expense[]
  payments SettlementPayment[]
  activityLogs ActivityLog[]
  notifications Notification[]
  customCategories CustomCategory[]
  backupRecords    BackupRecord[]
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  name            String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  ownedTrips      Trip[]              @relation("TripOwner")
  members         Member[]
  createdExpenses Expense[]           @relation("ExpenseCreator")
  sessions        Session[]
  settledPayments SettlementPayment[] @relation("SettlementMarkedBy")
  activityLogs    ActivityLog[]       @relation("ActivityLogUser")
  notifications   Notification[]
  notificationPreference NotificationPreference?
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Member {
  id        String   @id @default(cuid())
  name      String
  tripId    String
  userId    String?
  createdAt DateTime @default(now())

  trip              Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  payments          Expense[]           @relation("PaidBy")
  splits            Split[]
  outgoingPayments  SettlementPayment[] @relation("SettlementFromMember")
  incomingPayments  SettlementPayment[] @relation("SettlementToMember")

  @@unique([tripId, name])
  @@unique([tripId, userId])
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  currency    String   @default("TWD")
  exchangeRate Float   @default(1.0)
  category    String
  description String
  note        String?
  settlementMode String   @default("normal")
  settlementNote String?
  date        DateTime
  receiptUrl  String?
  splitType   String   @default("equal")
  paidById    String
  tripId      String
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paidBy    Member  @relation("PaidBy", fields: [paidById], references: [id], onDelete: Cascade)
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  splits    Split[]
}

model Split {
  id        String @id @default(cuid())
  amount    Float
  memberId  String
  expenseId String

  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([memberId, expenseId])
}

model SettlementPayment {
  id          String   @id @default(cuid())
  tripId      String
  fromMemberId String
  toMemberId  String
  amount      Float
  currency    String
  note        String?
  status      String   @default("completed")
  settledById String
  settledAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip      Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromMember Member @relation("SettlementFromMember", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   Member @relation("SettlementToMember", fields: [toMemberId], references: [id], onDelete: Cascade)
  settledBy User   @relation("SettlementMarkedBy", fields: [settledById], references: [id], onDelete: Cascade)

  @@index([tripId, status])
}

model ActivityLog {
  id         String   @id @default(cuid())
  tripId     String
  userId     String?
  action     String
  targetType String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation("ActivityLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  tripId    String?
  type      String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model CustomCategory {
  id        String   @id @default(cuid())
  tripId    String
  value     String
  label     String
  emoji     String   @default("📝")
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, value])
  @@index([tripId])
}

model NotificationPreference {
  id                String  @id @default(cuid())
  userId            String  @unique
  expenseCreated    Boolean @default(true)
  expenseUpdated    Boolean @default(true)
  expenseDeleted    Boolean @default(true)
  memberAdded       Boolean @default(true)
  memberRemoved     Boolean @default(true)
  paymentMarked     Boolean @default(true)
  paymentUpdated    Boolean @default(true)
  backupImported    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackupRecord {
  id        String   @id @default(cuid())
  tripId    String
  fileName  String
  filePath  String
  fileSize  Int
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}
